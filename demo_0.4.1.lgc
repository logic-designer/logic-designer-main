      "id": "6dd17d4b-6da7-4a76-b0b1-228e9864a5cd",
      "defId": "mcu",
      "x": 432,
      "y": 1512,
      "rot": 0,
      "name": "MCU (C/Arduino)",
      "outputs": [
        true
      ],
      "state": {
        "mcuCode": "#define F_CPU 16000000UL   // CPU frequency (16 MHz for Arduino Uno)\n\n#include <avr/io.h>\n#include <util/delay.h>\n\nint main(void)\n{\n    // Set PB5 (Pin 13) as output\n    DDRB |= (1 << PB5); #io\n\n    while (1)\n    {\n        // Turn LED ON\n        PORTB |= (1 << PB5);\n\n        _delay_ms(500);\n\n        // Turn LED OFF\n        PORTB &= ~(1 << PB5);\n\n        _delay_ms(500);\n    }\n}",
        "mcuVars": {
          "ddra": 0,
          "ddrb": 0,
          "ddrc": 0,
          "ddrd": 0,
