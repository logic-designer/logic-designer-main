      "name": "MCU (C/Arduino)",
      "outputs": [
        true
      ],
      "state": {
        "mcuCode": "void setup() {\npinMode(13, OUTPUT);   // Set pin 13 as output\n}\n\nvoid loop() {\ndigitalWrite(13, HIGH);  // LED ON\ndelay(500);\n\ndigitalWrite(13, LOW);   // LED OFF\ndelay(500);\n}\n",
        "mcuVars": {},
        "mcuOutputs": {
          "d13": true
        },
        "mcuDiagnostics": [],
        "mcuCanRun": true
      }
    },
