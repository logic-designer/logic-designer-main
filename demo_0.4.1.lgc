          "portb": 0,
          "portc": 0,
          "portd": 0,
          "pina": 0,
          "pinb": 0,
          "pinc": 0,
          "pind": 0
        },
        "mcuOutputs": {
          "pb5": true
        },
        "mcuDiagnostics": [],
        "mcuCanRun": true
      }
